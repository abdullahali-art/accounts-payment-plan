# GoHighLevel — Private Integration Token (sub-account)
GHL_API_KEY=

# Sub-account location ID (use either name; app reads both)
GHL_LOCATION_ID=
# GHL_sub-account_Location=

# Optional: force Accounts pipeline to this stage id after Generate & Send (e.g. "Payment Plan Sent").
# If unset, the app moves one stage forward using pipeline stage order from GHL.
# GHL_ACCOUNTS_TARGET_STAGE_ID=

# Public URL of this app — used to build the payment_plan_app_link written to GHL.
# e.g. https://your-app.vercel.app
APP_BASE_URL=

# n8n webhook — Automation 2 trigger (Payment Plan Submitted → JSON + Xero invoices).
# App POSTs the full Section 7 JSON blob to this URL on every Generate & Send.
# Hardcoded in process-payment-plan/route.ts — update there if the URL changes.
# N8N_WEBHOOK_URL=https://n8n.srv826531.hstgr.cloud/webhook/95be72f5-acb2-4cde-bc9a-75bfb2471dff
