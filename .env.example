# GoHighLevel — Private Integration Token (sub-account)
GHL_API_KEY=

# Sub-account location ID (use either name; app reads both)
GHL_LOCATION_ID=
# GHL_sub-account_Location=

# Optional: force Accounts pipeline to this stage id after Generate & Send (e.g. Payment Plan Sent).
# If unset, the app moves one stage forward using pipeline stage order from GHL.
# GHL_ACCOUNTS_TARGET_STAGE_ID=

# Optional — only if you still use n8n elsewhere (not required for core flow)
# N8N_API=
# N8N_WEBHOOK_URL=
# N8N_WORKFLOW_PRODUCTION_URL=
